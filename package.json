{
  "name": "fkcoding-note",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler pages dev src/index.ts",
    "build": "mkdir -p dist && cp -r src/assets/* dist/ && echo \"export { default } from '../src/index.ts';\" > dist/_worker.js",
    "deploy": "wrangler pages deploy dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply fkcoding-note --remote"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "drizzle-orm": "^0.31.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "wrangler": "^3.60.0",
    "drizzle-kit": "^0.22.0",
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
